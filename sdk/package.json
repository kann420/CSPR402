{
  "name": "cspr402",
  "version": "0.4.7",
  "description": "CSPR402 SDK and CLI for Casper testnet payment verification and mock virtual cards",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.js"
    }
  },
  "bin": {
    "cspr402": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src/__tests__/client.test.ts src/__tests__/config.test.ts src/__tests__/errors.test.ts src/__tests__/integration.test.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "casper",
    "cspr",
    "testnet",
    "virtual-card",
    "vcc",
    "ai-agent",
    "mcp",
    "model-context-protocol",
    "402-payment",
    "cep18",
    "cspr402"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kann420/CSPR402.git"
  },
  "homepage": "https://cspr402.xyz",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "axios": "^1.15.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
