# =============================================================================
# CardCasper402 backend - environment variables
# Copy to .env.local or .env and fill in local values. Never commit secrets.
# =============================================================================

# Server
PORT=4000
NODE_ENV=development

# Database
DB_PATH=./cards402.db

# Payment provider
PAYMENT_PROVIDER=casper

# Casper mainnet CSPR payment instructions
CASPER_NETWORK=mainnet
CASPER_CHAIN_NAME=casper
CASPER_NODE_RPC_URL=https://casper-mainnet.gateway.tatum.io/rpc
CASPER_TREASURY_PUBLIC_KEY=
# Fallback/pinned CSPR/USD rate. With CSPR_PRICE_FEED_ENABLED=true
# (default) orders are quoted at the live CoinGecko price and this value
# is only used when the feed is unreachable; set the flag to false to
# pin all pricing to this rate.
CSPR_USD_RATE=0.01
CSPR_PRICE_FEED_ENABLED=true
CASPER_MIN_TRANSFER_MOTES=2500000000
CASPER_PAYMENT_TTL_MINUTES=60

# Optional mockUSDC CEP-18 rail for Casper mainnet demos.
MOCK_USDC_ENABLED=false
MOCK_USDC_CONTRACT_PACKAGE_HASH=
MOCK_USDC_CONTRACT_HASH=
MOCK_USDC_DECIMALS=6

# Stellar - ops wallet used by xlm-sender to pay the CTX gift-card
# supplier (outbound settlement only; agent payment intake is Casper).
STELLAR_NETWORK=mainnet
STELLAR_USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
# STELLAR_XLM_SECRET=             # Ops wallet secret key

# VCC fulfillment service (still mocked for this MVP)
VCC_API_BASE=https://vcc.ctx.com
CARDS402_BASE_URL=http://localhost:4000
VCC_CALLBACK_SECRET=
CARDS402_SECRET_BOX_KEY=

# CORS - comma-separated allowed origins for the agent API (optional)
# CORS_ORIGINS=http://localhost:3000

# Bootstrap owner - optional for local dev
# OWNER_EMAIL=owner@example.com

# Internal dashboard access - optional
# INTERNAL_EMAILS=ops@example.com,eng@example.com
