# =============================================================================
# CardCasper402 backend - Casper MVP environment variables
# Copy to .env and fill in local values. Never commit .env or private keys.
# =============================================================================

# Server
PORT=4000
NODE_ENV=development
DB_PATH=./cardcasper402.db

# Product mode
PAYMENT_PROVIDER=casper
MOCK_CARD_MODE=true
VIRTUAL_CARD_PROVIDER=mock

# Casper mainnet (default)
CASPER_NETWORK=mainnet
CASPER_CHAIN_NAME=casper
CASPER_NODE_RPC_URL=https://casper-mainnet.gateway.tatum.io/rpc
CASPER_EVENT_STREAM_URL=https://node.cspr.cloud/events/main
CSPR_USD_RATE=0.01
CASPER_MIN_TRANSFER_MOTES=2500000000
CASPER_PAYMENT_TTL_MINUTES=60

# ── Mainnet (real CSPR) ─────────────────────────────────────────────────────
# Flip to mainnet by overriding the four vars below. The JSON-RPC contract is
# identical to testnet (verified: info_get_status + state_get_account_info with
# struct params behave the same on mainnet), so NO code changes are needed —
# verification checks the deploy's chain_name, so CASPER_CHAIN_NAME MUST be
# 'casper' when CASPER_NETWORK=mainnet (the env validator rejects a mismatch at
# boot). Leave MOCK_USDC_ENABLED=false on mainnet (CEP-18 mockUSDC is testnet).
#
# Public mainnet RPC (free, no-auth, ~5 req/min — fine for a demo):
#   https://casper-mainnet.gateway.tatum.io/rpc
# For higher volume (no 5 req/min limit), use CSPR.cloud (https://node.cspr.cloud)
# — it requires an Authorization header with a raw access token (register at
# cspr.cloud). Set CASPER_NODE_RPC_AUTH to that token (no "Bearer " prefix); the
# backend sends it on every Casper RPC call (verify + funding poller).
#
# CASPER_NETWORK=mainnet
# CASPER_CHAIN_NAME=casper
# CASPER_NODE_RPC_URL=https://node.cspr.cloud
# CASPER_NODE_RPC_AUTH=<your-cspr.cloud-access-token>
# CASPER_EVENT_STREAM_URL=
# CSPR_USD_RATE=<live USD/CSPR rate, e.g. 0.05>

# Treasury/payment account
# Public key is safe to commit for a demo account.
# Private key material must stay in ignored local files.
CASPER_TREASURY_PUBLIC_KEY=
CASPER_TREASURY_PRIVATE_KEY_PATH=

# Payment verification
CASPER_MIN_CONFIRMATIONS=1
CASPER_PAYMENT_TIMEOUT_MS=900000

# Optional mockUSDC CEP-18 support
MOCK_USDC_ENABLED=false
# Required when MOCK_USDC_ENABLED=true. Prefer the package hash for transfer verification.
MOCK_USDC_CONTRACT_PACKAGE_HASH=
# Optional display/query metadata after deployment.
MOCK_USDC_CONTRACT_HASH=
MOCK_USDC_DECIMALS=6

# VCC fulfillment service remains mocked for the MVP card flow.
VCC_API_BASE=https://vcc.ctx.com

# Public base URL used for receipts/webhooks in local demos.
CARDS402_BASE_URL=http://localhost:4000

# Secrets. Generate locally and keep out of git.
# Example: openssl rand -hex 32
CARDS402_SECRET_BOX_KEY=
VCC_CALLBACK_SECRET=

# CORS - comma-separated allowed origins for browser clients.
# CORS_ORIGINS=http://localhost:3000
