{
  "name": "cspr402-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "web",
    "sdk",
    "video"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck -w web --if-present && npm run typecheck -w sdk --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build -w sdk && npm run build -w web",
    "api:generate": "openapi-typescript api/agent-api.openapi.yaml -o api/agent-api.d.ts && openapi-typescript api/vcc-internal.openapi.yaml -o api/vcc-internal.d.ts",
    "api:validate": "node ./scripts/api-validate.mjs",
    "verify": "./scripts/verify.sh",
    "prepare": "husky"
  },
  "overrides": {
    "axios": "^1.15.0",
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.0.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.64.0"
  },
  "lint-staged": {
    "*.{js,ts,tsx,mjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
